# .env.example
# Template for local environment variables.
# Copy this file to `.env.local` and fill in your values.
# NEVER commit `.env.local` or any file containing real secrets.
#
# Vite env variable rules:
#   - Variables MUST be prefixed with VITE_ to be exposed to the browser bundle
#   - Access via: import.meta.env.VITE_YOUR_VAR
#   - Variables without VITE_ prefix are server-only (not accessible in browser)
#
# For Netlify deployment:
#   Site Settings → Environment Variables → Add variable

# Base URL of the REST API backend
# Development: http://localhost:4000
# Production:  https://your-api.example.com
VITE_API_BASE_URL=
